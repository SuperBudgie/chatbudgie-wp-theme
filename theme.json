{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "1120px",
      "wideSize": "1240px"
    },
    "color": {
      "palette": [
        { "slug": "bg", "name": "Background", "color": "#f4f7fb" },
        { "slug": "surface", "name": "Surface", "color": "#ffffff" },
        { "slug": "text", "name": "Text", "color": "#101933" },
        { "slug": "muted", "name": "Muted", "color": "#5d6a86" },
        { "slug": "primary", "name": "Primary", "color": "#1f6fff" },
        { "slug": "line", "name": "Line", "color": "#dbe6fb" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Inter,sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|bg",
      "text": "var:preset|color|text"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|inter",
      "lineHeight": "1.6"
    },
    "elements": {
      "button": {
        "border": { "radius": "12px" },
        "color": { "background": "var:preset|color|primary", "text": "#fff" },
        "spacing": { "padding": { "top": "12px", "right": "20px", "bottom": "12px", "left": "20px" } }
      }
    },
    "blocks": {
      "core/group": {
        "border": { "radius": "20px" }
      }
    }
  },
  "templateParts": [
    {"name": "header", "title": "Header", "area": "header"},
    {"name": "footer", "title": "Footer", "area": "footer"}
  ]
}
